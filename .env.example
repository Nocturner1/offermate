# Anthropic API Key
# Erhalte deinen Key auf: https://console.anthropic.com
# In Railway: Variables → ANTHROPIC_API_KEY = sk-ant-...
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL Verbindungs-URL
# Lokal: postgresql://user:password@localhost:5432/offermate
# Railway: wird automatisch gesetzt wenn PostgreSQL-Plugin hinzugefügt wird
DATABASE_URL=postgresql://user:password@localhost:5432/offermate
